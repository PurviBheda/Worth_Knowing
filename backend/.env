# Database connection string for PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worth_knowing?schema=public"

# Backend server port
PORT=5000

# Admin token for protected endpoints
ADMIN_TOKEN=secret-admin-token

# ── AI Provider Configuration ─────────────────────────────────────────────────
# Set AI_PROVIDER to: gemini | openai | anthropic
AI_PROVIDER=gemini

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (optional – only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API Key (optional – only needed if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Minimum confidence score below which articles are flagged for review (0.0 – 1.0)
AI_CONFIDENCE_THRESHOLD=0.6

# ── GNews API Configuration ───────────────────────────────────────────────────
# Get a free API key at https://gnews.io/ to load premium categorized news.
# If left blank, the platform automatically falls back to our robust free RSS feeds.
GNEWS_API_KEY=your_gnews_api_key_here

